# ── Certificado Digital A1 ────────────────────────────────────
# Caminho para o arquivo .pfx do certificado A1
NFSE_A1_PATH=/caminho/para/certificado.pfx

# Senha do certificado
NFSE_A1_PASSWORD=sua_senha_aqui

# ── API ADN NFS-e ─────────────────────────────────────────────
# URL de produção
NFSE_CONTRIBUINTE_URL=https://adn.nfse.gov.br/contribuintes

# URL de homologação (para testes)
# NFSE_CONTRIBUINTE_URL=https://adn.producaorestrita.nfse.gov.br/contribuintes

# ── Configuração da empresa ───────────────────────────────────
# Nome da empresa (usado como pasta raiz dos XMLs)
NFSE_EMPRESA=minha_empresa

# Arquivo de estado (NSU por CNPJ)
NFSE_STATE_FILE=state.json
